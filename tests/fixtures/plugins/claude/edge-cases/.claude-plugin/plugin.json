{
  "name": "edge-cases",
  "version": "0.5.0",
  "description": "Plugin exercising out-of-coverage Claude features so converter warnings fire",
  "author": "Plain string author",
  "hooks": {
    "on_pre_tool_use": [
      {"command": "scripts/pre.sh"}
    ],
    "on_tab_complete": [
      {"command": "scripts/tab.sh"}
    ],
    "on_keystroke": [
      {"command": "scripts/key.sh"}
    ]
  },
  "outputStyles": {"primary": "magenta"},
  "lspServers": {"python": {"command": "pyright-langserver"}},
  "futureField": {"unknownPayload": "x"},
  "agents": "agents/*.md",
  "skills": "skills/*.md",
  "providesTools": [
    "valid.module:Tool",
    "this is not formatted correctly"
  ]
}
